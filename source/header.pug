include mixins/svg

mixin header(isCatalog = false)
  header.header(class={ 'header--catalog': isCatalog })
    .section__container
      .header__wrapper
        .header__brand
          +icon('logo-mobile', 'header__logo header__logo--mobile', 96, 15)
          +icon('logo-desktop', 'header__logo header__logo--desktop', 200, 50)
        include nav
        include contacts 
        
      if isCatalog
        .header__bottom
          h1.header__title Попутчики
include mixins/svg.pug

-
  const transportKinds = ['plane', 'bus', 'cycle', 'foot'];
  const transportIconMeta = {
    plane: { w: 23, h: 22 },
    bus: { w: 18, h: 20 },
    cycle: { w: 25, h: 25 },
    foot: { w: 21, h: 24 },
  };
  const transportIconText = {
    plane: 'Самолёт',
    bus: 'Автобус',
    cycle: 'Велосипед',
    foot: 'Пешком',
  };
  const countryFlagBasename = {
    thailand: 'thailand-flag',
    czech: 'czech-flag',
    belgium: 'belgium-flag',
  };
  const countryFlagAlt = {
    'sri-lanka': 'Шри-Ланка',
    thailand: 'Таиланд',
    seychelles: 'Сейшелы',
    belgium: 'Бельгия',
    czech: 'Чехия',
  };
  const levelRingSize = 60;
  const levelRingStroke = 4;
  const levelRingRActual = (levelRingSize - levelRingStroke) / 2;
  const levelRingC = 2 * Math.PI * levelRingRActual;
  const people = [{ id: 'firsova', name: 'Таня Фирсова', level: '99', about: '#ЗОЖ #ПП #Фитнес #пляж #авокадо #смузи', transport: ['plane'], country : ['sri-lanka', 'thailand', 'seychelles'], defaultChecked: false, image: { webp1x: 'images/firsova@1x.webp', webp2x: 'images/firsova@2x.webp', png1x: 'images/firsova@1x.png', png2x: 'images/firsova@2x.png' } }, { id: 'demin', name: 'Петя Демин', level: '80', about: '#бургер #бар #футбол #концерт #крафт', transport: ['plane', 'bus', 'foot'], country : ['belgium', 'czech'], defaultChecked: true, image: { webp1x: 'images/demin@1x.webp', webp2x: 'images/demin@2x.webp', png1x: 'images/demin@1x.png', png2x: 'images/demin@2x.png' } }];

.fellow-travelers__people-block
  h3.fellow-travelers__people-title.visually-hidden Выберите попутчиков
  ul.fellow-travelers__people.list-reset
    each person in people
      - const levelProgress = Math.min(100, Math.max(0, Number(person.level)));
      - const levelRingDashOffset = levelRingC * (1 - levelProgress / 100);
      li.fellow-travelers__people-item
        a.fellow-travelers__people-link(href="#")
          .fellow-travelers__photo-container
            .fellow-travelers__photo-image
              picture
                source(
                  srcset=`${person.image.webp1x} 1x, ${person.image.webp2x} 2x`
                  type="image/webp"
                )
                source(
                  srcset=`${person.image.png1x} 1x, ${person.image.png2x} 2x`
                  type="image/png"
                )
                img.fellow-travelers__photo-image-picture(src=person.image.png1x alt=`${person.name}`)
              .fellow-travelers__photo-level-container
                span.fellow-travelers__photo-image-level
                  svg.fellow-travelers__photo-image-level-ring(
                    width=levelRingSize
                    height=levelRingSize
                    viewBox=`0 0 ${levelRingSize} ${levelRingSize}`
                    aria-hidden="true"
                    focusable="false"
                  )
                    circle.fellow-travelers__photo-image-level-ring-track(
                      cx=levelRingSize / 2
                      cy=levelRingSize / 2
                      r=levelRingRActual
                      fill="none"
                      stroke-width=levelRingStroke
                    )
                    circle.fellow-travelers__photo-image-level-ring-progress(
                      cx=levelRingSize / 2
                      cy=levelRingSize / 2
                      r=levelRingRActual
                      fill="none"
                      stroke-width=levelRingStroke
                      stroke-linecap="round"
                      stroke-dasharray=levelRingC
                      stroke-dashoffset=levelRingDashOffset
                      transform=`rotate(-90 ${levelRingSize / 2} ${levelRingSize / 2})`
                    )
                  span.fellow-travelers__photo-image-level-inner
                    span.fellow-travelers__photo-image-level-value= person.level
                    span.fellow-travelers__photo-image-level-label level
          .fellow-travelers__person-card
            .fellow-travelers__person-icon-flag
              ul.fellow-travelers__photo-flag-list.list-reset
                each countryCode in person.country
                  - const flagBase = countryFlagBasename[countryCode] ?? countryCode;
                  - const webp1x = `images/${flagBase}@1x.webp`;
                  - const webp2x = `images/${flagBase}@2x.webp`;
                  - const png1x = `images/${flagBase}@1x.png`;
                  - const png2x = `images/${flagBase}@2x.png`;
                  - const flagAlt = `Флаг: ${countryFlagAlt[countryCode] || countryCode}`;
                  li.fellow-travelers__photo-flag-item(
                    data-tooltip=countryFlagAlt[countryCode] || countryCode
                  )
                    picture
                      source(
                        srcset=`${webp1x} 1x, ${webp2x} 2x`
                        type="image/webp"
                      )
                      source(
                        srcset=`${png1x} 1x, ${png2x} 2x`
                        type="image/png"
                      )
                      img.fellow-travelers__photo-flag-picture(src=png1x alt=flagAlt)

            .fellow-travelers__person-text
              .fellow-travelers__person-container-name
                span.fellow-travelers__person-name-status(class=person.defaultChecked && 'fellow-travelers__person-name-status--online')
                .fellow-travelers__person-name= person.name
              .fellow-travelers__person-about!= person.about
              .fellow-travelers__person-container-transport
                ul.fellow-travelers__transport.list-reset
                  each kind in transportKinds
                    - const meta = transportIconMeta[kind]
                    - const isTransportChecked = person.transport.includes(kind)
                    li.fellow-travelers__transport-item(
                      class=isTransportChecked && 'fellow-travelers__transport-item--checked'
                      data-tooltip=transportIconText[kind]
                    )
                      span.fellow-travelers__transport-icon(
                        class=`fellow-travelers__transport-icon--${kind}`
                        style=`width:${meta.w}px;height:${meta.h}px`
                        aria-hidden="true"
                      )